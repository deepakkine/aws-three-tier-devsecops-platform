############################################
# Project Configuration
############################################

project_name = "aws-three-tier-devsecops-platform"
environment  = "dev"

############################################
# AWS Configuration
############################################

aws_region = "ap-south-1"

############################################
# VPC Configuration
############################################

vpc_cidr = "10.0.0.0/16"

public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24"
]

private_subnet_cidrs = [
  "10.0.11.0/24",
  "10.0.12.0/24"
]

availability_zones = [
  "ap-south-1a",
  "ap-south-1b"
]

############################################
# Amazon EKS
############################################

cluster_version = "1.31"

node_instance_types = [
  "t3.small"
]

desired_size = 3
min_size     = 3
max_size     = 4

############################################
# Alertmanager
############################################

alertmanager_email = "your-email@example.com"

# SMTP App Password
alertmanager_email_password = "your-smtp-app-password"

############################################
# GitHub
############################################

github_owner      = "your-github-username"
github_repository = "your-repository-name"

############################################
# Let's Encrypt
############################################

letsencrypt_email = "your-email@example.com"