############################################
# Argo CD
############################################

resource "helm_release" "argocd" {
  name       = "argocd"
  repository = "https://argoproj.github.io/argo-helm"
  chart      = "argo-cd"
  version    = "8.3.2"

  namespace        = "argocd"
  create_namespace = true

  wait    = true
  timeout = 900

  set = [
    {
      name  = "server.service.type"
      value = "ClusterIP"
    },
    {
      name  = "configs.params.server.insecure"
      value = "true"
    }
  ]

  depends_on = [
    helm_release.ingress_nginx
  ]
}